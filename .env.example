DISCORD_TOKEN=replace_with_your_bot_token
DISCORD_CLIENT_ID=replace_with_your_application_client_id
DISCORD_GUILD_ID=replace_with_your_server_id

RECORDINGS_DIR=/recordings
MAX_UPLOAD_MB=24

# Optional: enables automatic speaker-separated transcripts on /stop.
OPENAI_API_KEY=replace_with_your_openai_api_key
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_LANGUAGE=ja
